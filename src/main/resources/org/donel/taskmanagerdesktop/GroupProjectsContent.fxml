<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="content-scroll"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.donel.taskmanagerdesktop.Controllers.GroupProjectsController">
   <content>
      <VBox spacing="25" styleClass="content-area">
         <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>

         <HBox alignment="CENTER_LEFT">
            <Label text="Your Group Projects" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="newProjectButton" onAction="#handleNewProject" text="+ New Project" styleClass="primary-button"/>
         </HBox>

         <Label fx:id="statusLabel" text="Loading projects..." styleClass="subtitle" managed="false" visible="false"/>

         <VBox fx:id="projectListContainer" spacing="15"/>
      </VBox>
   </content>
</ScrollPane>
