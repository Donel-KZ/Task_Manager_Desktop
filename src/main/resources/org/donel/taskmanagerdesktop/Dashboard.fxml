<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            prefWidth="1280.0"
            prefHeight="720.0"
            stylesheets="@styles.css"
            styleClass="root">

   <!-- ================= LEFT SIDEBAR ================= -->

   <left>

      <VBox prefWidth="240"
            spacing="12"
            styleClass="sidebar">

         <padding>
            <Insets top="25" right="15" bottom="25" left="15"/>
         </padding>

         <HBox spacing="10" alignment="CENTER_LEFT">
            <children>
               <Label text="Task Manager"
                      styleClass="sidebar-title"/>
            </children>
         </HBox>

         <Separator/>

         <Button text="🏠 Home"
                 maxWidth="Infinity"
                 styleClass="nav-button"/>

         <Button text="📝 Pending"
                 maxWidth="Infinity"
                 styleClass="nav-button"/>

         <Button text="✅ Finished"
                 maxWidth="Infinity"
                 styleClass="nav-button"/>

         <Button text="⚠ Overdue"
                 maxWidth="Infinity"
                 styleClass="nav-button"/>

         <Button text="👥 Group Projects"
                 maxWidth="Infinity"
                 styleClass="nav-button"/>

         <Button text="📅 Calendar"
                 maxWidth="Infinity"
                 styleClass="nav-button"/>

         <Region VBox.vgrow="ALWAYS"/>

         <Button text="⚙ Settings"
                 maxWidth="Infinity"
                 styleClass="nav-button"/>

      </VBox>

   </left>

   <!-- ================= HEADER ================= -->

   <top>

      <HBox alignment="CENTER_LEFT"
            spacing="15"
            prefHeight="70"
            styleClass="top-bar">

         <padding>
            <Insets top="15" right="25" bottom="15" left="25"/>
         </padding>

         <Label text="Dashboard"
                styleClass="page-title"/>

         <Region HBox.hgrow="ALWAYS"/>

         <TextField promptText="Search tasks..."
                    prefWidth="300"
                    styleClass="search-field"/>

         <Button text="🔔"
                 styleClass="icon-button"/>

         <Button text="👤"
                 styleClass="icon-button"/>

      </HBox>

   </top>

   <!-- ================= MAIN CONTENT ================= -->

   <center>

      <ScrollPane fitToWidth="true"
                  hbarPolicy="NEVER"
                  styleClass="content-scroll">

         <content>

            <VBox spacing="25"
                  styleClass="content-area">

               <padding>
                  <Insets top="25"
                          right="25"
                          bottom="25"
                          left="25"/>
               </padding>

               <!-- Welcome -->

               <VBox spacing="5">

                  <Label text="Welcome Back!"
                         styleClass="welcome-title"/>

                  <Label text="Here's an overview of your tasks today."
                         styleClass="subtitle"/>

               </VBox>

               <!-- Dashboard Cards -->

               <HBox spacing="20">

                  <VBox spacing="8"
                        prefWidth="220"
                        styleClass="dashboard-card">

                     <Label text="Total Tasks"
                            styleClass="card-title"/>

                     <Label text="18"
                            styleClass="card-value"/>

                  </VBox>

                  <VBox spacing="8"
                        prefWidth="220"
                        styleClass="dashboard-card">

                     <Label text="Pending"
                            styleClass="card-title"/>

                     <Label text="8"
                            styleClass="card-value"/>

                  </VBox>

                  <VBox spacing="8"
                        prefWidth="220"
                        styleClass="dashboard-card">

                     <Label text="Finished"
                            styleClass="card-title"/>

                     <Label text="10"
                            styleClass="card-value"/>

                  </VBox>

                  <VBox spacing="8"
                        prefWidth="220"
                        styleClass="dashboard-card">

                     <Label text="Overdue"
                            styleClass="card-title"/>

                     <Label text="2"
                            styleClass="card-value"/>

                  </VBox>

               </HBox>

               <!-- Tasks -->

               <VBox spacing="15">

                  <HBox alignment="CENTER_LEFT">

                     <Label text="Today's Tasks"
                            styleClass="section-title"/>

                     <Region HBox.hgrow="ALWAYS"/>

                     <Button text="+ Add Task"
                             styleClass="primary-button"/>

                  </HBox>

                  <!-- Task Card -->

                  <StackPane prefHeight="80"
                             styleClass="task-card">

                     <HBox alignment="CENTER_LEFT"
                           spacing="20">

                        <padding>
                           <Insets top="15"
                                   right="20"
                                   bottom="15"
                                   left="20"/>
                        </padding>

                        <Label text="☐"/>

                        <VBox spacing="4">

                           <Label text="Finish JavaFX Desktop UI"
                                  styleClass="task-title"/>

                           <Label text="Priority: High • Due Today"
                                  styleClass="task-subtitle"/>

                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="Edit"
                                styleClass="secondary-button"/>

                     </HBox>

                  </StackPane>

                  <!-- Another Task -->

                  <StackPane prefHeight="80"
                             styleClass="task-card">

                     <HBox alignment="CENTER_LEFT"
                           spacing="20">

                        <padding>
                           <Insets top="15"
                                   right="20"
                                   bottom="15"
                                   left="20"/>
                        </padding>

                        <Label text="☑"/>

                        <VBox spacing="4">

                           <Label text="Connect Spring Boot Backend"
                                  styleClass="task-title"/>

                           <Label text="Completed Yesterday"
                                  styleClass="task-subtitle"/>

                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="View"
                                styleClass="secondary-button"/>

                     </HBox>

                  </StackPane>

               </VBox>

            </VBox>

         </content>

      </ScrollPane>

   </center>

</BorderPane>