<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true"
            hbarPolicy="NEVER"
            styleClass="content-scroll">

    <content>
        <VBox spacing="25" styleClass="content-area">
            <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>

            <HBox alignment="CENTER_LEFT">
                <Label text="Finished Tasks (10)" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <VBox spacing="15">

                <StackPane prefHeight="80" styleClass="task-card">
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
                        <Label text="☑"/>
                        <VBox spacing="4">
                            <Label text="Connect Spring Boot Backend" styleClass="task-title"/>
                            <Label text="Completed Yesterday" styleClass="task-subtitle"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Done" styleClass="status-badge status-badge-done"/>
                        <Button text="View" styleClass="secondary-button"/>
                    </HBox>
                </StackPane>

                <StackPane prefHeight="80" styleClass="task-card">
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
                        <Label text="☑"/>
                        <VBox spacing="4">
                            <Label text="Push iOS TaskManager to GitHub" styleClass="task-title"/>
                            <Label text="Completed 3 days ago" styleClass="task-subtitle"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Done" styleClass="status-badge status-badge-done"/>
                        <Button text="View" styleClass="secondary-button"/>
                    </HBox>
                </StackPane>

            </VBox>
        </VBox>
    </content>

</ScrollPane>
