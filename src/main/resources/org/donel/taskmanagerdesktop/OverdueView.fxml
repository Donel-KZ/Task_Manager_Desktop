<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true"
            hbarPolicy="NEVER"
            styleClass="content-scroll">

    <content>
        <VBox spacing="25" styleClass="content-area">
            <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>

            <VBox spacing="5">
                <Label text="Overdue Tasks (2)" styleClass="section-title"/>
                <Label text="These tasks have passed their due date." styleClass="subtitle"/>
            </VBox>

            <VBox spacing="15">

                <StackPane prefHeight="80" styleClass="task-card">
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
                        <Label text="☐"/>
                        <VBox spacing="4">
                            <Label text="Fix Room 2.6.1 + KSP2 conflict" styleClass="task-title"/>
                            <Label text="Was due 2 days ago" styleClass="task-subtitle"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Overdue" styleClass="status-badge status-badge-overdue"/>
                        <Button text="Edit" styleClass="secondary-button"/>
                    </HBox>
                </StackPane>

                <StackPane prefHeight="80" styleClass="task-card">
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
                        <Label text="☐"/>
                        <VBox spacing="4">
                            <Label text="Submit research proposal draft" styleClass="task-title"/>
                            <Label text="Was due yesterday" styleClass="task-subtitle"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Overdue" styleClass="status-badge status-badge-overdue"/>
                        <Button text="Edit" styleClass="secondary-button"/>
                    </HBox>
                </StackPane>

            </VBox>
        </VBox>
    </content>

</ScrollPane>
