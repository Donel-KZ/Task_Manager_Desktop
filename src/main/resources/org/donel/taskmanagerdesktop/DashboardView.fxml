<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true"
            hbarPolicy="NEVER"
            styleClass="content-scroll">

    <content>

        <VBox spacing="25" styleClass="content-area">

            <padding>
                <Insets top="25" right="25" bottom="25" left="25"/>
            </padding>

            <!-- Welcome -->

            <VBox spacing="5">

                <Label text="Welcome Back!"
                       styleClass="welcome-title"/>

                <Label text="Here's an overview of your tasks today."
                       styleClass="subtitle"/>

            </VBox>

            <!-- Dashboard Cards -->

            <HBox spacing="20">

                <VBox prefWidth="220"
                      spacing="8"
                      styleClass="dashboard-card">

                    <Label text="Total Tasks"
                           styleClass="card-title"/>

                    <Label text="18"
                           styleClass="card-value"/>

                </VBox>

                <VBox prefWidth="220"
                      spacing="8"
                      styleClass="dashboard-card">

                    <Label text="Pending"
                           styleClass="card-title"/>

                    <Label text="8"
                           styleClass="card-value"/>

                </VBox>

                <VBox prefWidth="220"
                      spacing="8"
                      styleClass="dashboard-card">

                    <Label text="Finished"
                           styleClass="card-title"/>

                    <Label text="10"
                           styleClass="card-value"/>

                </VBox>

                <VBox prefWidth="220"
                      spacing="8"
                      styleClass="dashboard-card">

                    <Label text="Overdue"
                           styleClass="card-title"/>

                    <Label text="2"
                           styleClass="card-value"/>

                </VBox>

            </HBox>

            <!-- Today's Tasks -->

            <VBox spacing="15">

                <HBox alignment="CENTER_LEFT">

                    <Label text="Today's Tasks"
                           styleClass="section-title"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="+ Add Task"
                            styleClass="primary-button"/>

                </HBox>

                <StackPane prefHeight="80"
                           styleClass="task-card">

                    <HBox alignment="CENTER_LEFT"
                          spacing="20">

                        <padding>
                            <Insets top="15" right="20" bottom="15" left="20"/>
                        </padding>

                        <Label text="☐"/>

                        <VBox spacing="4">

                            <Label text="Finish JavaFX Desktop UI"
                                   styleClass="task-title"/>

                            <Label text="Priority: High • Due Today"
                                   styleClass="task-subtitle"/>

                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="Edit"
                                styleClass="secondary-button"/>

                    </HBox>

                </StackPane>

                <StackPane prefHeight="80"
                           styleClass="task-card">

                    <HBox alignment="CENTER_LEFT"
                          spacing="20">

                        <padding>
                            <Insets top="15" right="20" bottom="15" left="20"/>
                        </padding>

                        <Label text="☑"/>

                        <VBox spacing="4">

                            <Label text="Connect Spring Boot Backend"
                                   styleClass="task-title"/>

                            <Label text="Completed Yesterday"
                                   styleClass="task-subtitle"/>

                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="View"
                                styleClass="secondary-button"/>

                    </HBox>

                </StackPane>

            </VBox>

        </VBox>

    </content>

</ScrollPane>