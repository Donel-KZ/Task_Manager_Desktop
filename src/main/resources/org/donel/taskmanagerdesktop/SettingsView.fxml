<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.donel.taskmanagerdesktop.Controllers.SettingsController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            styleClass="content-scroll">

    <content>

        <VBox spacing="30" styleClass="content-area">

            <padding>
                <Insets top="25" right="25" bottom="25" left="25"/>
            </padding>

            <!-- Profile -->
            <VBox spacing="12">
                <Label text="Profile" styleClass="settings-section-title"/>
                <VBox styleClass="settings-panel">
                        <HBox alignment="CENTER_LEFT" spacing="18" styleClass="settings-row">
                            <ImageView fx:id="avatarImageView" fitHeight="72" fitWidth="72" pickOnBounds="true" preserveRatio="true" styleClass="avatar-image"/>
                            <VBox spacing="4">
                                <Label fx:id="nameLabel" text="Loading user..." styleClass="settings-label"/>
                                <Label fx:id="emailLabel" text="Loading email..." styleClass="settings-sublabel"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="uploadProfilePictureButton" text="Upload Photo" styleClass="secondary-button" onAction="#handleUploadProfilePicture"/>
                        </HBox>
                    <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                        <VBox spacing="2">
                            <Label text="Account status" styleClass="settings-label"/>
                            <Label text="Live session profile" styleClass="settings-sublabel"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Synced" disable="true" styleClass="secondary-button"/>
                    </HBox>

                </VBox>
            </VBox>

            <!-- Preferences -->
            <VBox spacing="12">
                <Label text="Preferences" styleClass="settings-section-title"/>
                <VBox styleClass="settings-panel">

                    <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                        <VBox spacing="2">
                            <Label text="Email notifications" styleClass="settings-label"/>
                            <Label text="Get notified about due and overdue tasks" styleClass="settings-sublabel"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <CheckBox selected="true" styleClass="settings-toggle"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                        <VBox spacing="2">
                            <Label text="Desktop notifications" styleClass="settings-label"/>
                            <Label text="Show alerts when tasks are due soon" styleClass="settings-sublabel"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <CheckBox selected="true" styleClass="settings-toggle"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                        <VBox spacing="2">
                            <Label text="Start on launch" styleClass="settings-label"/>
                            <Label text="Open Task Manager automatically at login" styleClass="settings-sublabel"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <CheckBox selected="false" styleClass="settings-toggle"/>
                    </HBox>

                </VBox>
            </VBox>

            <!-- Account -->
            <VBox spacing="12">
                <Label text="Account" styleClass="settings-section-title"/>
                <VBox styleClass="settings-panel">

                    <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                        <VBox spacing="2">
                            <Label text="Log out" styleClass="settings-label"/>
                            <Label text="Sign out of Task Manager on this device" styleClass="settings-sublabel"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Log Out" styleClass="secondary-button"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" styleClass="settings-row">
                        <VBox spacing="2">
                            <Label text="Delete account" styleClass="settings-label"/>
                            <Label text="Permanently delete your account and data" styleClass="settings-sublabel"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Delete" styleClass="danger-button"/>
                    </HBox>

                </VBox>
            </VBox>

        </VBox>

    </content>

</ScrollPane>
