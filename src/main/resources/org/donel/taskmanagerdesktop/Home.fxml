<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1280.0" stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.donel.taskmanagerdesktop.Controllers.HomeController"
>


   <left>

      <VBox prefWidth="240" spacing="12" styleClass="sidebar">

         <padding>
            <Insets bottom="25" left="15" right="15" top="25" />
         </padding>

         <HBox alignment="CENTER_LEFT" spacing="10">
            <children>
               <Label styleClass="sidebar-icon" text="📋" />
               <Label styleClass="sidebar-title" text="Task Manager" />
            </children>
         </HBox>

         <Separator />

         <Button fx:id="homeButton"
                 text="Home"
                 onAction="#showHome"/>

         <Button fx:id="pending"
                 text="Pending"
                 onAction="#showPending"/>

         <Button fx:id="finished"
                 text="Finished"
                 onAction="#showFinished"/>

         <Button fx:id="overdue"
                 text="Overdue"
                 onAction="#showOverdue"/>

         <Button fx:id="calendar"
                 text="Calendar"
                 onAction="#showCalendar"/>

         <Button fx:id="groupProjects"
                 text="Group Projects"
                 onAction="#showGroupProjects"/>

         <Button fx:id="settings"
                 text="Settings"
                 onAction="#showSettings"/>

      </VBox>

   </left>

   <!-- ================= HEADER ================= -->

   <top>

      <HBox alignment="CENTER_LEFT" prefHeight="70" spacing="15" styleClass="top-bar">

         <padding>
            <Insets bottom="15" left="25" right="25" top="15" />
         </padding>

         <Label styleClass="page-title" text="Dashboard" />

         <Region HBox.hgrow="ALWAYS" />

         <TextField prefWidth="300" promptText="Search tasks..." styleClass="search-field" />

         <Button styleClass="icon-button" text="🔔" />

         <Button styleClass="icon-button" text="👤" />

      </HBox>

   </top>

   <!-- ================= MAIN CONTENT ================= -->

   <center>
         <ScrollPane fx:id="contentArea"
                     fitToWidth="true"
                     hbarPolicy="NEVER"
                     styleClass="content-scroll"/>

   </center>

</BorderPane>
