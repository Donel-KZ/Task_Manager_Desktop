<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true"
            hbarPolicy="NEVER"
            styleClass="content-scroll">

    <content>
        <VBox spacing="25" styleClass="content-area">
            <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>

            <HBox alignment="CENTER_LEFT">
                <Label text="Pending Tasks (8)" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ Add Task" styleClass="primary-button"/>
            </HBox>

            <VBox spacing="15">

                <StackPane prefHeight="80" styleClass="task-card">
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
                        <Label text="☐"/>
                        <VBox spacing="4">
                            <Label text="Finish JavaFX Desktop UI" styleClass="task-title"/>
                            <Label text="Due Today" styleClass="task-subtitle"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="High" styleClass="status-badge status-badge-high"/>
                        <Button text="Edit" styleClass="secondary-button"/>
                    </HBox>
                </StackPane>

                <StackPane prefHeight="80" styleClass="task-card">
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
                        <Label text="☐"/>
                        <VBox spacing="4">
                            <Label text="Write project README" styleClass="task-title"/>
                            <Label text="Due in 2 days" styleClass="task-subtitle"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Medium" styleClass="status-badge status-badge-medium"/>
                        <Button text="Edit" styleClass="secondary-button"/>
                    </HBox>
                </StackPane>

                <StackPane prefHeight="80" styleClass="task-card">
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
                        <Label text="☐"/>
                        <VBox spacing="4">
                            <Label text="Review pull request #42" styleClass="task-title"/>
                            <Label text="Due in 5 days" styleClass="task-subtitle"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Low" styleClass="status-badge status-badge-low"/>
                        <Button text="Edit" styleClass="secondary-button"/>
                    </HBox>
                </StackPane>

            </VBox>
        </VBox>
    </content>

</ScrollPane>
