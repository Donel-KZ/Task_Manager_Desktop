<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true"
            hbarPolicy="NEVER"
            styleClass="content-scroll">

    <content>
        <VBox spacing="25" styleClass="content-area">
            <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>

            <HBox alignment="CENTER_LEFT">
                <Label text="Your Group Projects" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ New Project" styleClass="primary-button"/>
            </HBox>

            <VBox spacing="15">

                <VBox spacing="12" styleClass="group-card">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Parking Management System" styleClass="group-title"/>
                            <Label text="4 members • 3 deliverables • Due in 6 days" styleClass="group-meta"/>
                        </VBox>
                        <Button text="Open" styleClass="secondary-button"/>
                    </HBox>
                    <ProgressBar progress="0.65" prefWidth="Infinity" maxWidth="Infinity" styleClass="group-progress-bar"/>
                    <Label text="65% complete" styleClass="group-meta"/>
                </VBox>

                <VBox spacing="12" styleClass="group-card">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Eduvos Research Design Proposal" styleClass="group-title"/>
                            <Label text="2 members • 1 deliverable • Due in 12 days" styleClass="group-meta"/>
                        </VBox>
                        <Button text="Open" styleClass="secondary-button"/>
                    </HBox>
                    <ProgressBar progress="0.3" prefWidth="Infinity" maxWidth="Infinity" styleClass="group-progress-bar"/>
                    <Label text="30% complete" styleClass="group-meta"/>
                </VBox>

            </VBox>
        </VBox>
    </content>

</ScrollPane>
